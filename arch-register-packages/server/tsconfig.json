{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@diagram-craft/utils/*": ["../../packages/utils/src/*"],
      "@diagram-craft/collaboration/*": ["../../packages/collaboration/src/*"],
      "@diagram-craft/model/*": ["../../packages/model/src/*"],
      "@diagram-craft/canvas/*": ["../../packages/canvas/src/*"],
      "@diagram-craft/geometry/*": ["../../packages/geometry/src/*"],
      "@diagram-craft/graph/*": ["../../packages/graph/src/*"]
    }
  },
  "include": ["src"]
}
