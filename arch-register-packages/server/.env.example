DATABASE_URL=postgresql://postgres:password@localhost:5432/arch_register

# CORS — restrict in production (e.g., https://your-app.example.com)
CORS_ORIGIN=*                            # '*' allows all origins (dev only)

# Development-only artificial API latency simulation
DEV_API_DELAY_MS=0                       # Average delay in milliseconds
DEV_API_DELAY_VARIANCE_MS=0              # Random variance applied as ±ms

# Authentication Configuration
AUTH_MODE=local                           # 'local' or 'oidc'
JWT_SECRET=your-secret-key-here-min-32-characters-required
JWT_ACCESS_TOKEN_EXPIRY=1h               # Access token expiration (e.g., 1h, 30m)
JWT_REFRESH_TOKEN_EXPIRY=7d              # Refresh token expiration (e.g., 7d, 30d)

# OIDC Configuration (only required if AUTH_MODE=oidc)
OIDC_ISSUER=https://your-oidc-provider.com
OIDC_CLIENT_ID=your-client-id
OIDC_CLIENT_SECRET=your-client-secret
OIDC_REDIRECT_URI=http://localhost:3010/api/auth/oidc/callback
OIDC_SCOPE=openid profile email          # Space-separated scopes
OIDC_FRONTEND_REDIRECT_URI=/             # Where to redirect after OIDC callback

# AI (OpenRouter) — optional, enables the AI sidebar in the diagram editor
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# AI API key encryption — strongly recommended for production
# AI_ENCRYPTION_KEY: if not set, workspace AI provider keys are stored as plaintext;
#   a warning is logged at startup.
AI_ENCRYPTION_KEY=

# AI_ENCRYPTION_SALT: salt used when deriving the encryption key via scrypt.
#   If not set, falls back to a hardcoded default (existing encrypted values remain
#   readable, but using a unique per-deployment salt is recommended for new deployments).
AI_ENCRYPTION_SALT=
