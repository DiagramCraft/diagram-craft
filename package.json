{
  "name": "diagram-craft",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "packageManager": "pnpm@9.3.0",
  "scripts": {
    "client:dev": "pnpm run -C packages/main dev",
    "client:build": "pnpm run -C packages/main build",
    "client:preview": "pnpm run -C packages/main preview",
    "electron:dev": "pnpm run -C packages/electron-app dev",
    "electron:build": "pnpm run -C packages/main build && pnpm run -C packages/electron-app build",
    "electron:start": "pnpm run -C packages/electron-app start",
    "electron:pack": "pnpm run -C packages/electron-app pack",
    "electron:dist": "pnpm run -C packages/main build && pnpm run -C packages/electron-app build && pnpm run -C packages/electron-app dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:bench": "vitest bench --run",
    "lint:tsc": "tsc --noEmit",
    "lint": "biome lint --max-diagnostics=100 && tsc --noEmit",
    "doc": "typedoc"
  },
  "keywords": [],
  "author": "Magnus Johansson",
  "pnpm": {
    "overrides": {
      "ws": "^8.18.0",
      "braces": "^3.0.3",
      "micromatch": "^4.0.8",
      "nanoid": "^3.3.8",
      "esbuild": "^0.25.0",
      "picomatch@2.3.1": "^2.3.2",
      "picomatch@4.0.2": "^4.0.4",
      "picomatch@4.0.3": "^4.0.4",
      "brace-expansion@2.0.1": "^2.0.2",
      "brace-expansion@1.1.12": "^1.1.13",
      "brace-expansion@2.0.2": "^2.0.3",
      "minimatch@5.1.9>brace-expansion": "^2.0.3",
      "brace-expansion@5.0.4": "^5.0.5",
      "form-data": ">=4.0.4",
      "axios": ">=1.13.5",
      "glob@11.0.3": ">=11.1.0",
      "glob@10.4.5": ">=10.5.0",
      "js-yaml": ">=4.1.1",
      "yaml@1.10.2": "^1.10.3",
      "yaml@2.8.1": "^2.8.3",
      "@isaacs/brace-expansion": ">=5.0.1",
      "tar": ">=7.5.11",
      "minimatch@10.0.1": ">=10.2.4",
      "@xmldom/xmldom": ">=0.8.12",
      "@tootallnate/once": ">=3.0.1",
      "defu": ">=6.1.6",
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1"
