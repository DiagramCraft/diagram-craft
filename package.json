{
  "name": "diagram-craft",
  "version": "0.1.0",
  "description": "",
  "main": "index.js",
  "type": "module",
  "packageManager": "pnpm@9.3.0",
  "scripts": {
    "client:dev": "pnpm run -C packages/main dev",
    "client:build": "pnpm run -C packages/main build",
    "client:preview": "pnpm run -C packages/main preview",
    "electron:dev": "pnpm run -C packages/electron-app dev",
    "electron:build": "pnpm run -C packages/main build && pnpm run -C packages/electron-app build",
    "electron:start": "pnpm run -C packages/electron-app start",
    "electron:pack": "pnpm run -C packages/electron-app pack",
    "electron:dist": "pnpm run -C packages/main build && pnpm run -C packages/electron-app build && pnpm run -C packages/electron-app dist",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:bench": "vitest bench --run",
    "lint:tsc": "tsc --noEmit",
    "lint": "biome lint --max-diagnostics=100 && tsc --noEmit",
    "doc": "typedoc"
  },
  "keywords": [],
  "author": "Magnus Johansson",
  "pnpm": {
    "overrides": {
      "ws": "^8.18.0",
      "braces": "^3.0.3",
      "micromatch": "^4.0.8",
      "nanoid": "^3.3.8",
      "esbuild": "^0.25.0",
      "form-data": ">=4.0.4",
      "axios": ">=1.15.0",
      "js-yaml": ">=4.1.1",
      "tar": ">=7.5.11",
      "@xmldom/xmldom": "0.8.13",
      "@tootallnate/once": ">=3.0.1",
      "defu": ">=6.1.6",
      "lodash": ">=4.18.1",
      "lodash-es": ">=4.18.1"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@codspeed/vitest-plugin": "^5.2.0",
    "@rollup/plugin-yaml": "^4.1.2",
    "@types/jsdom": "^28.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "prettier": "^3.6.2",
    "skott": "^0.35.10",
    "syncpack": "^14.3.0",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typedoc-github-theme": "^0.4.0",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "globals": "^17.0.0"
  }
}
