{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext"],
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": true,
    "paths": {
      "@diagram-craft/electron-client-api/*": ["../electron-client-api/src/*"],
      "@diagram-craft/utils/*": ["../utils/src/*"]
    },
    "rootDirs": ["./src", "../electron-client-api/src/*", "../utils/src/*"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
